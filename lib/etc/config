# CircleMUD runtime configuration.
#
# Each line is `key value`.  Blank lines and lines beginning with # are
# ignored.  Any key omitted keeps the compile-time default from
# src/config.c.  String values may use \r, \n, \t escapes.
#
# This file is shipped as the distribution default at lib/etc/config and
# copied to lib-run/etc/config by bootstrap.sh.  Edit the copy in
# lib-run/, not this file.

